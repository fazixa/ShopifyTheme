{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&family=Schoolbell&display=swap"
>
{% # theme-check-enable RemoteAsset %}

{% style %}
  /* ── Sketchbook: Hand-drawn font overrides ── */
  :root {
    --font-body--family: 'Schoolbell', cursive;
    --font-body--style: normal;
    --font-body--weight: 400;
    --font-subheading--family: 'Schoolbell', cursive;
    --font-subheading--style: normal;
    --font-subheading--weight: 400;
    --font-heading--family: 'Schoolbell', cursive;
    --font-heading--style: normal;
    --font-heading--weight: 400;
    --font-accent--family: 'Schoolbell', cursive;
    --font-accent--style: normal;
    --font-accent--weight: 400;
  }

  /* Scale all rem-based font sizes up by 1px from the root */
  html {
    font-size: 17px;
  }

  body {
    letter-spacing: 0.01em;
  }

  /* ── Product descriptions + accordion headers: Exo 2 font ── */
  .rte,
  rte-formatter,
  .accordion {
    font-family: 'Exo 2', sans-serif !important;
    --summary-font-family: 'Exo 2', sans-serif !important;
    --summary-font-size: 1.125rem !important;
    font-weight: 400;
  }

  /* ── Sketchbook: Line boil — letterform shape distortion ── */
  @keyframes sk-text-boil {
    0%   { filter: url(#sk-tb-1); }
    20%  { filter: url(#sk-tb-2); }
    40%  { filter: url(#sk-tb-3); }
    60%  { filter: url(#sk-tb-4); }
    80%  { filter: url(#sk-tb-5); }
    100% { filter: url(#sk-tb-1); }
  }

  h1, h2, h3, h4, h5, h6,
  .h1:not(.text-block),
  .h2:not(.text-block),
  .h3:not(.text-block),
  .h4:not(.text-block),
  .h5:not(.text-block),
  .h6:not(.text-block),
  .header-logo,
  .menu-list__link {
    animation: sk-text-boil 1.25s steps(5, end) infinite;
    will-change: filter;
  }

  /* ── Sketchbook: Wobbly accordion dividers ── */
  .accordion--dividers .details {
    position: relative;
    border-block-start: none !important;
    border-block-end: none !important;
    margin-block-end: 0;
  }

  .accordion--dividers .details::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 10px;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      var(--color-border) 40%,
      var(--color-border) 60%,
      transparent 60%
    );
    filter: url(#sk-wobble);
    pointer-events: none;
  }

  .accordion--dividers accordion-custom:last-child .details::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 10px;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      var(--color-border) 40%,
      var(--color-border) 60%,
      transparent 60%
    );
    filter: url(#sk-wobble);
    pointer-events: none;
  }

  /* ── Sketchbook: Wobbly header separator line ── */
  .header__row--top:not(.divider--page-width),
  .header__row--top.divider--page-width .header__columns,
  .header__row--bottom {
    position: relative;
    overflow: visible;
    border-bottom: none !important;
  }

  .header__row--top:not(.divider--page-width)::after,
  .header__row--top.divider--page-width .header__columns::after,
  .header__row--bottom::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 10px;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      var(--color-foreground) 40%,
      var(--color-foreground) 60%,
      transparent 60%
    );
    opacity: 0.35;
    filter: url(#sk-wobble);
    pointer-events: none;
  }

  /* ── Exo 2 font for product action elements ── */
  .variant-option__button-label,
  .variant-option legend,
  .quantity-selector,
  .add-to-cart-button,
  product-price,
  .price__regular,
  .price__sale,
  .price,
  .compare-at-price {
    font-family: 'Exo 2', sans-serif !important;
  }

  /* ── Exo 2 for cart drawer and cart page — excluding product titles ── */
  .cart-items-component *,
  .cart-page *,
  .cart-totals * {
    font-family: 'Exo 2', sans-serif !important;
  }

  .cart-items-component .cart-items__title,
  .cart-items-component .cart-items__title *,
  .cart-page .cart-title,
  .cart-page .cart-title h1,
  .cart-page .cart-title h2,
  .cart-page .cart-title h3,
  .cart-drawer .cart-drawer__heading,
  .cart-drawer .cart-drawer__heading.h4,
  .cart-drawer__heading,
  .cart-drawer__heading.h4 {
    font-family: var(--font-heading--family) !important;
  }

  /* ── Sketchbook: Wobbly quantity box and add-to-cart button outlines ── */
  .quantity-selector {
    position: relative;
    border-color: transparent !important;
  }

  .quantity-selector::after {
    content: '';
    position: absolute;
    inset: 0;
    border: var(--style-border-width-inputs) solid var(--color-input-border);
    border-radius: var(--style-border-radius-inputs);
    filter: url(#sk-wobble-btn);
    pointer-events: none;
    z-index: 10;
  }


  /* ── Sketchbook: Wobbly variant size button outlines ── */
  /* Hide the native border and theme's fake-border ::before overlay */
  .variant-option__button-label:not(.variant-option__button-label--has-swatch) {
    border-color: transparent !important;
  }
  .variant-option__button-label:not(.variant-option__button-label--has-swatch)::before {
    display: none;
  }
  /* Wobbly border drawn on a separate span so text is unaffected */
  .sk-btn-border {
    position: absolute;
    inset: 0;
    border: var(--options-border-width) solid var(--color-variant-border);
    border-radius: inherit;
    filter: url(#sk-wobble-btn);
    will-change: filter;
    pointer-events: none;
    z-index: 10;
  }
  .variant-option__button-label:hover .sk-btn-border {
    border-color: var(--color-variant-hover-border);
  }
  .variant-option__button-label:has(:checked) .sk-btn-border {
    border-color: var(--color-selected-variant-border);
  }

  /* ── Size guide popup trigger link ── */
  .size-guide-popup {
    display: block;
    margin-top: var(--margin-xs);
  }

  .size-guide-popup__trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--gap-2xs);
    font-family: 'Exo 2', sans-serif;
    font-size: var(--font-size--sm);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    color: var(--color-foreground);
    opacity: 0.75;
  }

  .size-guide-popup__trigger:hover {
    opacity: 1;
  }

  .size-guide-popup__trigger svg {
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
  }

  /* ── Size guide dialog modal ── */
  .size-guide-popup__dialog {
    box-shadow: var(--shadow-popover);
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    background-color: var(--color-background);
    padding: var(--padding-4xl) var(--padding-xl) var(--padding-xl);
    max-width: min(90vw, 640px);
    max-height: var(--modal-max-height);
    width: 100%;
    overflow-y: auto;

    @media screen and (min-width: 750px) {
      padding: var(--padding-5xl);
    }
  }

  .size-guide-popup__dialog[open] {
    animation: modalSlideInTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .size-guide-popup__dialog.dialog-closing {
    animation: modalSlideOutTop var(--animation-speed) var(--animation-easing) forwards;
  }

  .size-guide-popup__heading {
    font-family: var(--font-heading--family) !important;
    font-size: var(--font-size--lg);
    margin-block-end: var(--margin-lg);
  }

  .size-guide-popup__close {
    position: absolute;
    top: var(--margin-sm);
    right: var(--margin-sm);
    opacity: 0.8;
  }

  .size-guide-popup__content {
    font-family: 'Exo 2', sans-serif;
    font-size: var(--font-size--sm);
  }

  .size-guide-popup__content table {
    width: 100%;
    border-collapse: collapse;
  }

  .size-guide-popup__content th,
  .size-guide-popup__content td {
    padding: var(--padding-xs) var(--padding-sm);
    border: var(--style-border-width) solid var(--color-border);
    text-align: center;
  }

  .size-guide-popup__content th {
    font-weight: 600;
    background: rgb(var(--color-foreground-rgb) / 0.05);
  }

  /* ── Sketchbook: Wobbly footer separator line ── */
  .utilities {
    position: relative;
    border-top: none !important;
  }

  .utilities::before {
    content: '';
    position: absolute;
    top: -5px;
    left: 0;
    right: 0;
    height: 10px;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      var(--color-foreground) 40%,
      var(--color-foreground) 60%,
      transparent 60%
    );
    opacity: 0.35;
    filter: url(#sk-wobble);
    pointer-events: none;
  }
{% endstyle %}
